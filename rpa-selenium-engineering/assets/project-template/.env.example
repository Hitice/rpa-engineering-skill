# Copy to .env and fill real values. .env is gitignored.

RPA_PROCESS_NAME=rpa-template
RPA_TARGET_URL=https://example.invalid/
RPA_USERNAME=changeme
RPA_PASSWORD=changeme

RPA_BROWSER=chrome
RPA_HEADLESS=true

# Intra-call retry budget for transient errors (network / timeouts).
# RETRY_INITIAL_DELAY_S is the lower bound of the exponential backoff and
# also the upper bound of the random jitter added on top.
RPA_RETRY_ATTEMPTS=3
RPA_RETRY_INITIAL_DELAY_S=0.5
RPA_RETRY_MAX_DELAY_S=5

# Cross-run attempt budget before promoting an item to DEAD_LETTER
RPA_MAX_ATTEMPTS=3

# Persistent state and single-instance lock. Leave empty to disable.
RPA_STATE_DB_PATH=./artifacts/state.db
RPA_LOCK_PATH=./artifacts/run.lock
RPA_LOCK_TIMEOUT_S=10

RPA_DEFAULT_TIMEOUT_S=15
RPA_SUBMIT_TIMEOUT_S=30

RPA_ARTIFACTS_DIR=./artifacts
RPA_LOG_LEVEL=INFO

# Comma-separated list (case-insensitive substring match). Defaults are
# applied when this variable is omitted; setting it here overrides them.
# RPA_REDACT_KEYS=password,token,secret,api_key,authorization,cookie,cpf,cnpj,ssn,credit_card

RPA_DRY_RUN=false
